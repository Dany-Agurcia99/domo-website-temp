// Problem -> Solution / Qué es DOMO
// Two columns: "Antes" (problem) vs "Con DOMO" (solution).

const PROBLEMS = [
  { icon: "search-x",  label: "Buscás por WhatsApp y nadie responde a tiempo." },
  { icon: "circle-help", label: "No sabés si el técnico es confiable o cobra de más." },
  { icon: "clock-alert", label: "Esperás todo el día sin saber si va a llegar." },
  { icon: "receipt-text", label: "Pagás en efectivo, sin garantía si algo sale mal." },
];

const SOLUTIONS = [
  { icon: "sparkles",     label: "Encontrá técnicos verificados en menos de un minuto." },
  { icon: "shield-check", label: "Profesionales con identidad confirmada y reseñas reales." },
  { icon: "calendar-clock", label: "Agenda en tiempo real con horario que vos elegís." },
  { icon: "badge-check",  label: "Precio acordado, pago seguro y garantía DOMO." },
];

function ProblemSolution() {
  return (
    <section id="que-es" data-screen-label="Que es DOMO" style={{background: "var(--domo-white)"}}>
      <div className="container">
        <div className="section-head">
          <span className="eyebrow">Qué es DOMO</span>
          <h2>Encontrar quién te ayude<br/>no debería ser un dolor de cabeza.</h2>
          <p>DOMO es la app que conecta hogares hondureños con técnicos verificados — desde plomería hasta limpieza profunda — sin grupos de WhatsApp, sin sorpresas, sin esperar todo el día.</p>
        </div>

        <div style={{
          display: "grid",
          gridTemplateColumns: "1fr auto 1fr",
          gap: 0,
          alignItems: "stretch",
          maxWidth: 1120, margin: "0 auto",
          background: "var(--domo-white)",
          borderRadius: 24,
          border: "1px solid var(--border-1)",
          boxShadow: "var(--shadow-2)",
          overflow: "hidden",
        }}>
          {/* Problem column */}
          <Column
            tone="problem"
            eyebrow="Antes"
            title="El proceso de siempre"
            items={PROBLEMS}
          />

          {/* Divider with chevron */}
          <div style={{
            width: 1, background: "var(--border-1)",
            position: "relative",
          }}>
            <div style={{
              position: "absolute", top: "50%", left: "50%",
              transform: "translate(-50%, -50%)",
              width: 48, height: 48, borderRadius: 999,
              background: "var(--accent)", color: "#fff",
              display: "flex", alignItems: "center", justifyContent: "center",
              boxShadow: "0 12px 24px -8px rgba(25,83,90,0.45)",
            }}>
              <Icon name="arrow-right" size={22} stroke="#fff" strokeWidth={2.2}/>
            </div>
          </div>

          {/* Solution column */}
          <Column
            tone="solution"
            eyebrow="Con DOMO"
            title="Servicios en una app"
            items={SOLUTIONS}
          />
        </div>
      </div>
    </section>
  );
}

function Column({ tone, eyebrow, title, items }) {
  const isSolution = tone === "solution";
  return (
    <div style={{
      padding: "40px 40px 44px",
      background: isSolution ? "var(--domo-sand-50)" : "#fff",
    }}>
      <div style={{
        fontSize: 11, fontWeight: 700, letterSpacing: "0.14em",
        textTransform: "uppercase",
        color: isSolution ? "var(--accent)" : "var(--fg-3)",
      }}>{eyebrow}</div>
      <h3 style={{
        margin: "10px 0 24px",
        fontFamily: "var(--font-display)", fontWeight: 700,
        fontSize: 24, letterSpacing: "-0.01em",
        color: "var(--domo-navy)",
        opacity: isSolution ? 1 : 0.78,
      }}>{title}</h3>

      <ul style={{
        listStyle: "none", padding: 0, margin: 0,
        display: "flex", flexDirection: "column", gap: 14,
      }}>
        {items.map((item, i) => (
          <li key={i} style={{
            display: "flex", alignItems: "flex-start", gap: 12,
            opacity: isSolution ? 1 : 0.72,
          }}>
            <div style={{
              flexShrink: 0,
              width: 34, height: 34, borderRadius: 10,
              background: isSolution ? "var(--domo-teal-50)" : "rgba(17,22,39,0.05)",
              display: "flex", alignItems: "center", justifyContent: "center",
              marginTop: 1,
            }}>
              <Icon name={item.icon} size={18}
                    stroke={isSolution ? "var(--accent)" : "var(--fg-2)"} strokeWidth={1.8}/>
            </div>
            <span style={{
              fontSize: 15, lineHeight: 1.5, paddingTop: 6,
              color: isSolution ? "var(--fg-1)" : "var(--fg-2)",
              textDecoration: isSolution ? "none" : "line-through",
              textDecorationColor: "rgba(17,22,39,0.18)",
              textDecorationThickness: "1px",
            }}>{item.label}</span>
          </li>
        ))}
      </ul>
    </div>
  );
}

window.ProblemSolution = ProblemSolution;
