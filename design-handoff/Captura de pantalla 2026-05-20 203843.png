// Trust / Credibility — verified, safe, made in Honduras, upcoming cities.

function Trust() {
  return (
    <section data-screen-label="Trust" style={{background: "var(--domo-white)"}}>
      <div className="container">
        <div className="section-head">
          <span className="eyebrow">Confianza primero</span>
          <h2>Una app construida con responsabilidad.</h2>
          <p>Verificamos a cada profesional en persona. Aseguramos cada servicio. Y lo hacemos desde Honduras, para Honduras.</p>
        </div>

        <div style={{
          display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 16,
        }}>
          <TrustCard
            icon="badge-check"
            title="Técnicos verificados"
            blurb="Entrevista en persona, verificación de identidad y referencias revisadas."
            stat="100%"
            statLabel="Verificados"
          />
          <TrustCard
            icon="shield-check"
            title="Seguro y confiable"
            blurb="Pagos protegidos, precio acordado y garantía DOMO en cada servicio."
            stat="L. 25k"
            statLabel="Cobertura por trabajo"
          />
          <TrustCard
            icon="heart-handshake"
            title="Hecho en Honduras"
            blurb="Construido en Tegucigalpa por un equipo hondureño, para hogares hondureños."
            stat="🇭🇳"
            statLabel="Orgullo catracho"
            statHero
          />
          <TrustCard
            icon="map-pin"
            title="Próximamente en Tegucigalpa"
            blurb="Lanzamos primero en la capital. San Pedro Sula, La Ceiba y Choloma siguen."
            stat="Q4 2026"
            statLabel="Próximo lanzamiento"
          />
        </div>

        {/* Coverage strip */}
        <CoverageStrip/>
      </div>
    </section>
  );
}

function TrustCard({ icon, title, blurb, stat, statLabel, statHero }) {
  const [hover, setHover] = React.useState(false);
  return (
    <article
      onMouseEnter={() => setHover(true)}
      onMouseLeave={() => setHover(false)}
      style={{
        background: "var(--domo-sand-50)",
        border: "1px solid var(--border-1)",
        borderRadius: 18,
        padding: "24px 22px 20px",
        display: "flex", flexDirection: "column", gap: 14,
        minHeight: 280,
        transition: "all var(--dur-base) var(--ease-standard)",
        transform: hover ? "translateY(-3px)" : "translateY(0)",
        boxShadow: hover ? "var(--shadow-3)" : "none",
      }}>
      <div style={{
        width: 44, height: 44, borderRadius: 12,
        background: "var(--domo-white)",
        border: "1px solid var(--border-1)",
        display: "flex", alignItems: "center", justifyContent: "center",
      }}>
        <Icon name={icon} size={22} stroke="var(--accent)" strokeWidth={1.8}/>
      </div>

      <h3 style={{
        margin: 0,
        fontFamily: "var(--font-display)", fontWeight: 700,
        fontSize: 18, lineHeight: 1.2, letterSpacing: "-0.01em",
        color: "var(--domo-navy)",
      }}>{title}</h3>

      <p style={{
        margin: 0, fontSize: 13.5, lineHeight: 1.55, color: "var(--fg-2)",
        flex: 1,
      }}>{blurb}</p>

      <div style={{
        marginTop: "auto", paddingTop: 12,
        borderTop: "1px solid var(--border-1)",
      }}>
        <div style={{
          fontFamily: "var(--font-display)", fontWeight: 700,
          fontSize: statHero ? 28 : 22, color: "var(--domo-navy)",
          letterSpacing: "-0.02em", lineHeight: 1,
        }}>{stat}</div>
        <div style={{
          fontSize: 11, fontWeight: 600, letterSpacing: "0.08em",
          textTransform: "uppercase", color: "var(--fg-3)", marginTop: 6,
        }}>{statLabel}</div>
      </div>
    </article>
  );
}

function CoverageStrip() {
  const cities = [
    { name: "Tegucigalpa",    badge: "Próximamente", primary: true },
    { name: "San Pedro Sula", badge: "En lista",     primary: false },
    { name: "La Ceiba",       badge: "En lista",     primary: false },
    { name: "Choloma",        badge: "En lista",     primary: false },
  ];
  return (
    <div style={{
      marginTop: 32,
      background: "var(--domo-sand-100)",
      borderRadius: 18,
      padding: "20px 28px",
      display: "flex", alignItems: "center", gap: 24, flexWrap: "wrap",
    }}>
      <div style={{
        display: "flex", alignItems: "center", gap: 12,
      }}>
        <div style={{
          width: 40, height: 40, borderRadius: 10,
          background: "var(--domo-white)",
          display: "flex", alignItems: "center", justifyContent: "center",
        }}>
          <Icon name="map" size={20} stroke="var(--accent)"/>
        </div>
        <div>
          <div style={{
            fontSize: 11, fontWeight: 700, letterSpacing: "0.10em",
            textTransform: "uppercase", color: "var(--accent)",
          }}>Cobertura</div>
          <div style={{
            fontFamily: "var(--font-display)", fontWeight: 700,
            fontSize: 17, color: "var(--domo-navy)", marginTop: 2,
          }}>4 ciudades en Honduras</div>
        </div>
      </div>
      <div style={{flex: 1}}/>
      <div style={{display: "flex", gap: 10, flexWrap: "wrap"}}>
        {cities.map(c => (
          <div key={c.name} style={{
            display: "inline-flex", alignItems: "center", gap: 8,
            padding: "8px 14px", borderRadius: 999,
            background: c.primary ? "var(--accent)" : "var(--domo-white)",
            color: c.primary ? "#fff" : "var(--fg-1)",
            border: `1px solid ${c.primary ? "var(--accent)" : "var(--border-1)"}`,
            fontSize: 13, fontWeight: 600,
          }}>
            <span style={{
              width: 6, height: 6, borderRadius: 999,
              background: c.primary ? "#9BD4D6" : "var(--accent)",
            }}/>
            {c.name}
            <span style={{
              fontSize: 11, opacity: c.primary ? 0.85 : 0.6,
              fontWeight: 500,
            }}>· {c.badge}</span>
          </div>
        ))}
      </div>
    </div>
  );
}

window.Trust = Trust;
