/* DOMO Landing v2 — Tally Latam-inspired aesthetic.
   - HUGE display type (Outfit 800)
   - Ultra-rounded cards (28-40px)
   - Curved section blocks (concave/convex transitions)
   - Vertical accent line motif on left edge
   - Same DOMO palette (teal, navy, sand)
*/

html, body { background: var(--domo-white); margin: 0; padding: 0; }
body {
  font-family: var(--font-sans);
  color: var(--fg-1);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ============ Lime / Mint accent tokens (extending colors_and_type.css) ============ */
:root {
  --lime:        #BCD476;
  --lime-mid:    #93CC95;
  --mint:        #73C3AF;
  --mint-soft:   #E2F1E8;   /* very soft mint wash for icon bgs */
  --lime-soft:   #F2F5D8;   /* very soft lime wash */
  --lime-grad:   linear-gradient(135deg, #BCD476 0%, #93CC95 55%, #73C3AF 100%);
  --lime-grad-soft: linear-gradient(135deg, #F2F5D8 0%, #E2F1E8 60%, #D6EFE4 100%);
}

/* ============ Container ============ */
.container { max-width: 1280px; margin: 0 auto; padding: 0 32px; }
.container--narrow { max-width: 960px; margin: 0 auto; padding: 0 32px; }
.container--wide { max-width: 1440px; margin: 0 auto; padding: 0 32px; }

/* ============ Vertical accent line motif (Tally Latam) ============
   A fixed-position thin teal line on the left edge of the page.
   Visible on desktop only — feels like a subtle brand frame. */
.v-line {
  position: fixed;
  left: 28px; top: 0; bottom: 0;
  width: 2px;
  background: linear-gradient(180deg,
    transparent 0%,
    var(--mint) 8%,
    var(--lime) 92%,
    transparent 100%);
  opacity: 0.75;
  z-index: 5;
  pointer-events: none;
}
@media (max-width: 980px) { .v-line { display: none; } }

/* ============ Buttons (chunkier, pill-only) ============ */
.btn {
  font-family: var(--font-sans);
  font-weight: 700;
  font-size: 15px;
  padding: 16px 26px;
  border-radius: 999px;
  border: 2px solid transparent;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  transition: all var(--dur-base) var(--ease-standard);
  white-space: nowrap;
  line-height: 1;
}
.btn:focus-visible { outline: 3px solid rgba(25,83,90,0.55); outline-offset: 3px; }
.btn.primary { background: var(--domo-navy); color: #fff; }
.btn.primary:hover { background: #000; transform: translateY(-2px); box-shadow: 0 16px 32px -12px rgba(17,22,39,0.45); }
.btn.primary:active { transform: translateY(0); }
.btn.accent { background: var(--accent); color: #fff; }
.btn.accent:hover { background: var(--accent-hover); transform: translateY(-2px); box-shadow: var(--shadow-accent); }
.btn.lime { background: var(--lime-grad); color: var(--domo-navy); border: none; font-weight: 800; }
.btn.lime:hover { transform: translateY(-2px); box-shadow: 0 18px 36px -12px rgba(115,195,175,0.55); }
.btn.outline { background: transparent; color: var(--domo-navy); border-color: var(--domo-navy); }
.btn.outline:hover { background: var(--domo-navy); color: #fff; }
.btn.outline.on-dark { color: #fff; border-color: rgba(255,255,255,0.4); }
.btn.outline.on-dark:hover { background: #fff; color: var(--domo-navy); border-color: #fff; }
.btn.ghost { background: transparent; color: var(--fg-1); border-color: transparent; }
.btn.ghost:hover { background: rgba(17,22,39,0.06); }
.btn.ghost.on-dark { color: #fff; }
.btn.ghost.on-dark:hover { background: rgba(255,255,255,0.10); }
.btn.lg { font-size: 16px; padding: 20px 32px; }
.btn.xl { font-size: 18px; padding: 24px 40px; gap: 12px; }
.btn.sm { font-size: 13px; padding: 11px 18px; }
.btn.full { width: 100%; justify-content: center; }

/* ============ Display type — the Tally Latam signature ============ */
.tally-display {
  font-family: var(--font-display);
  font-weight: 800;
  line-height: 0.95;
  letter-spacing: -0.035em;
  color: var(--domo-navy);
  margin: 0;
}
.tally-display .accent { color: var(--mint); }
.tally-display .lime { color: var(--lime); }
.tally-display .navy   { color: var(--domo-navy); }
.tally-display .mint   { color: var(--mint); }
.tally-display em { font-style: normal; color: var(--mint); }

.tally-display--xxl { font-size: clamp(48px, 7.5vw, 108px); }
.tally-display--xl  { font-size: clamp(40px, 6vw, 80px); }
.tally-display--lg  { font-size: clamp(36px, 4.5vw, 64px); }
.tally-display--md  { font-size: clamp(28px, 3.5vw, 48px); }

/* ============ Eyebrow ============ */
.eyebrow {
  font-family: var(--font-sans);
  font-weight: 800;
  font-size: 13px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--domo-navy);
  display: inline-flex;
  align-items: center;
  gap: 10px;
}
.eyebrow::before {
  content: "";
  width: 28px; height: 3px;
  background: var(--lime-grad);
  border-radius: 999px;
}
.eyebrow.on-dark { color: #fff; }
.eyebrow.on-dark::before { background: var(--lime); }

/* ============ Sections with curved corners ============ */
section { padding: 120px 0; position: relative; }
section.flush { padding: 0; }

/* Color blocks — each is a giant pill/rounded rect that creates the
   curved section transitions Tally Latam loves. */
.block {
  border-radius: 48px;
  padding: 96px 64px;
  position: relative;
  overflow: hidden;
}
.block.sand   { background: var(--domo-sand-100); }
.block.navy   { background: var(--domo-navy); color: #fff; }
.block.teal   { background: var(--domo-deep-teal); color: #fff; }
.block.lime   { background: var(--lime-grad); color: var(--domo-navy); }
.block.lime-soft { background: var(--lime-grad-soft); }
.block.cream  { background: var(--domo-sand-50); }
.block.white  { background: #fff; border: 1px solid var(--border-1); }

/* When two blocks stack, pull them together so the curves kiss */
.stack > * + * { margin-top: 24px; }

/* ============ Inputs ============ */
.field { display: flex; flex-direction: column; gap: 8px; }
.field label {
  font-size: 13px; font-weight: 700;
  color: var(--fg-1);
  letter-spacing: 0.01em;
}
.field input, .field select, .field textarea {
  font-family: var(--font-sans); font-size: 15px; color: var(--fg-1);
  padding: 16px 20px; border-radius: 16px;
  border: 2px solid var(--border-2);
  background: var(--domo-white); outline: none;
  transition: all var(--dur-base) var(--ease-standard);
}
.field input::placeholder, .field textarea::placeholder { color: var(--domo-ink-400); }
.field input:focus, .field select:focus, .field textarea:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 4px rgba(25,83,90,0.15);
}
.field .hint { font-size: 12px; color: var(--fg-3); }

/* ============ Ultra-rounded cards ============ */
.r-card {
  background: #fff;
  border-radius: 32px;
  padding: 32px;
  border: 1px solid var(--border-1);
  transition: all var(--dur-base) var(--ease-standard);
}
.r-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 30px 60px -28px rgba(17,22,39,0.25);
}
.r-card.flat { box-shadow: none; }
.r-card.sand { background: var(--domo-sand-100); }
.r-card.cream { background: var(--domo-sand-50); }
.r-card.teal-soft { background: var(--domo-teal-50); border-color: rgba(25,83,90,0.10); }
.r-card.mint-soft { background: var(--mint-soft); border-color: rgba(115,195,175,0.18); }
.r-card.lime { background: var(--lime-grad); color: var(--domo-navy); border: none; }

/* ============ Pill chips ============ */
.pill {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 10px 18px; border-radius: 999px;
  background: #fff;
  border: 1.5px solid var(--border-2);
  font-size: 13px; font-weight: 600; color: var(--fg-1);
}
.pill.accent { background: var(--accent); color: #fff; border-color: var(--accent); }
.pill.sand { background: var(--domo-sand-200); border-color: transparent; }
.pill.dark { background: var(--domo-navy); color: #fff; border-color: var(--domo-navy); }
.pill.on-dark { background: rgba(255,255,255,0.10); color: #fff; border-color: rgba(255,255,255,0.16); }
.pill .dot {
  width: 8px; height: 8px; border-radius: 999px; background: var(--accent);
  box-shadow: 0 0 0 4px rgba(25,83,90,0.18);
}
.pill.accent .dot, .pill.on-dark .dot { background: #9BD4D6; box-shadow: 0 0 0 4px rgba(94,174,177,0.25); }

/* ============ Stars ============ */
.stars { display: inline-flex; gap: 2px; }

/* ============ Phone mockup ============ */
.phone {
  position: relative;
  width: 320px; height: 660px;
  background: #0A0F1C;
  border-radius: 48px;
  padding: 12px;
  box-shadow:
    0 70px 140px -30px rgba(17, 22, 39, 0.55),
    0 30px 60px -20px rgba(17, 22, 39, 0.35),
    inset 0 0 0 2px rgba(255,255,255,0.06);
}
.phone__screen {
  position: relative;
  width: 100%; height: 100%;
  background: var(--domo-sand-100);
  border-radius: 38px;
  overflow: hidden;
}
.phone__notch {
  position: absolute; top: 12px; left: 50%; transform: translateX(-50%);
  width: 110px; height: 28px; background: #0A0F1C;
  border-radius: 999px; z-index: 30;
}

/* ============ Floating cards ============ */
.float-card {
  position: absolute;
  background: var(--domo-white);
  border-radius: 20px;
  padding: 14px 18px;
  box-shadow: 0 24px 60px -16px rgba(17,22,39,0.28), 0 8px 20px -8px rgba(17,22,39,0.14);
  display: flex; align-items: center; gap: 12px;
}

/* ============ Animations ============ */
@keyframes float-y {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12px); }
}
.float-anim-a { animation: float-y 7s ease-in-out infinite; }
.float-anim-b { animation: float-y 9s ease-in-out infinite reverse; }
.float-anim-c { animation: float-y 8s ease-in-out infinite; animation-delay: -2s; }

@keyframes fade-up {
  0% { opacity: 0; transform: translateY(20px); }
  100% { opacity: 1; transform: translateY(0); }
}
.fade-up { animation: fade-up 0.7s var(--ease-out-soft) both; }
.fade-up.d1 { animation-delay: 0.08s; }
.fade-up.d2 { animation-delay: 0.16s; }
.fade-up.d3 { animation-delay: 0.24s; }
.fade-up.d4 { animation-delay: 0.32s; }

@keyframes marquee-x {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ============ Hero icon float (Apple-style gentle 3D bob) ============ */
@keyframes hero-icon-bob {
  0%, 100% { transform: translateY(0) rotateZ(-1.5deg); }
  50%      { transform: translateY(-18px) rotateZ(1.5deg); }
}
.hero-icon-float {
  animation: hero-icon-bob 6s ease-in-out infinite;
  will-change: transform;
}
@media (prefers-reduced-motion: reduce) {
  .hero-icon-float { animation: none; }
}

/* ============ Marquee strip ============ */
.marquee {
  overflow: hidden;
  mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
}
.marquee__track {
  display: inline-flex; gap: 32px;
  white-space: nowrap;
  animation: marquee-x 40s linear infinite;
}

/* ============ Section head (centered) ============ */
.section-head { max-width: 880px; margin: 0 auto 72px; }
.section-head--center { text-align: center; margin-left: auto; margin-right: auto; }
.section-head h2 {
  margin: 18px 0 18px;
  font-family: var(--font-display); font-weight: 800;
  font-size: clamp(36px, 4.5vw, 68px);
  line-height: 0.98;
  letter-spacing: -0.035em;
  color: var(--domo-navy);
}
.section-head h2 .accent { color: var(--accent); }
.section-head h2 em { font-style: normal; color: var(--accent); }
.section-head p {
  color: var(--fg-2); font-size: 19px; line-height: 1.55; margin: 0;
  max-width: 640px;
}
.section-head--center p { margin-left: auto; margin-right: auto; }

/* ============ How It Works (full-bleed scroll-driven) ============ */
.hiw-head {
  position: relative; z-index: 2;
  text-align: center;
  padding: 48px 24px 0;
  flex-shrink: 0;
}
.hiw-stage {
  position: relative; z-index: 2;
  flex: 1; min-height: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 40px;
  padding: 0 6vw;
  width: 100%;
  box-sizing: border-box;
}
.hiw-copy {
  display: flex;
  gap: 36px;
  align-items: stretch;
  max-width: 620px;
  justify-self: end;
  width: 100%;
  height: 360px;
}
.hiw-rail {
  display: flex;
  flex-shrink: 0;
  padding: 6px 0;
}
.hiw-phone-wrap {
  display: flex;
  justify-content: flex-start;
  align-items: center;
}

/* Phone frame */
.hiw-phone {
  position: relative;
  width: clamp(300px, 30vw, 380px);
  aspect-ratio: 380 / 760;
  max-height: 80vh;
  background: #05070C;
  border-radius: 52px;
  padding: 12px;
  box-shadow:
    0 50px 100px -30px rgba(0,0,0,0.7),
    inset 0 0 0 2px rgba(255,255,255,0.06);
}
.hiw-phone__notch {
  position: absolute; top: 14px; left: 50%; transform: translateX(-50%);
  width: 120px; height: 30px; background: #05070C;
  border-radius: 999px; z-index: 10;
}
.hiw-phone__screen {
  position: relative;
  width: 100%; height: 100%;
  border-radius: 42px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

@media (max-width: 820px) {
  .hiw-stage { grid-template-columns: 1fr; gap: 28px; padding: 0 24px; }
  .hiw-phone-wrap { display: none; }
  .hiw-copy { justify-self: center; height: auto; min-height: 320px; }
}

/* ============ Footer (Busy Bee style) ============ */
.page-shell {
  position: relative;
  z-index: 1;
  background: #fff;
}
.footer-fixed {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  z-index: 0;
}
.footer-wide {
  width: 100%;
  padding: 0 40px;
  box-sizing: border-box;
}
.footer-wordmark {
  font-family: var(--font-display);
  font-weight: 800;
  color: #fff;
  text-align: center;
  line-height: 0.82;
  letter-spacing: -0.01em;
  font-size: 25vw;
  margin: 8px 0 18px;
  user-select: none;
  white-space: nowrap;
  text-shadow: 0.018em 0.02em 0 #B8D378;
}
@media (max-width: 700px) {
  .footer-wide { padding: 0 22px; }
  .footer-wordmark { font-size: 30vw; text-shadow: 0.022em 0.024em 0 #B8D378; }
}

/* ============ Trust grid — full-bleed ============ */
.trust-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  width: 100vw;
  position: relative;
  left: 50%;
  transform: translateX(-50%);
  padding: 0 40px;
  box-sizing: border-box;
  margin: 64px 0 0;
}
@media (max-width: 820px) {
  .trust-grid { grid-template-columns: 1fr; padding: 0 24px; }
}

/* ============ Category grid (Services) — full-bleed ============ */
.cat-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 20px;
  width: 100vw;
  position: relative;
  left: 50%;
  transform: translateX(-50%);
  padding: 0 40px;
  box-sizing: border-box;
  margin: 64px 0 0;
}
@media (max-width: 1000px) {
  .cat-grid { grid-template-columns: repeat(3, 1fr); padding: 0 24px; }
}
@media (max-width: 620px) {
  .cat-grid { grid-template-columns: repeat(2, 1fr); padding: 0 20px; }
}

/* ============ How it works (sticky scroll) ============ */
@media (max-width: 760px) {
  .hiw-grid { grid-template-columns: 1fr !important; gap: 28px !important; }
}

/* ============ Responsive ============ */
@media (max-width: 980px) {
  section { padding: 80px 0; }
  .container, .container--narrow, .container--wide { padding: 0 20px; }
  .block { padding: 64px 32px; border-radius: 36px; }
  .section-head { margin-bottom: 48px; }
}
